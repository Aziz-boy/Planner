# ── Telegram Bot ─────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Your personal Telegram chat ID
# Send /start to your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# Copy the "id" value from "chat" object
TELEGRAM_CHAT_ID=123456789

# ── Web Push (Browser Notifications) ─────────────────────────
# Generate VAPID keys by running:  node generate-vapid.js
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:shavgoniaziz@gmail.com

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── Planner website URL (your Netlify URL) ───────────────────
# Used as CORS origin for push subscription endpoint
PLANNER_URL=https://your-planner.netlify.app
