OPENAI_API_KEY=sk-proj-...

# ── Firebase Admin ────────────────────────────────────────────
# HOW TO GET:
# 1. Go to https://console.firebase.google.com
# 2. Select your project (life-planner-c5205)
# 3. Project Settings → Service Accounts tab
# 4. Click "Generate new private key" → download the JSON file
# 5. Run this command to encode it:
#    base64 -i /path/to/service-account.json | tr -d '\n'
# 6. Paste the output below
FIREBASE_SERVICE_ACCOUNT=base64encodedserviceaccountjsonhere

# ── Web Push (Browser Notifications) ─────────────────────────
